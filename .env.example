# ─── BASE DE DONNÉES ──────────────────────────────────────────────────────────
# Local (Docker) : npm run db:up puis utiliser ces URLs
# Port 5434 si 5432/5433 occupés — mot de passe = celui du volume Docker existant
DATABASE_URL="postgresql://postgres:[PASSWORD]@localhost:5434/lovepiment_dev"
DIRECT_URL="postgresql://postgres:[PASSWORD]@localhost:5434/lovepiment_dev"
# Production (Supabase) :
# DATABASE_URL = Transaction pooler (port 6543)
# DIRECT_URL   = Session pooler (port 5432) — même hôte pooler, PAS db.xxx.supabase.co si injoignable
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# ─── ORANGE MONEY (paiement direct compte marchand — Guinée) ─────────────────
# Inscription : boutique Orange Guinée + https://developer.orange.com/apis/om-webpay
ORANGE_MONEY_CLIENT_ID="[ORANGE_CLIENT_ID]"
ORANGE_MONEY_CLIENT_SECRET="[ORANGE_CLIENT_SECRET]"
ORANGE_MONEY_MERCHANT_KEY="[ORANGE_MERCHANT_KEY]"
# `gn` = production Guinée, `dev` = sandbox Orange
ORANGE_MONEY_COUNTRY_CODE="gn"
# ORANGE_MONEY_API_BASE_URL="https://api.orange.com"
# Vérifier la config : npm run verify:orange-money

# ─── IA (assistant shopping — Gemini) ─────────────────────────────────────────
# Clé gratuite : https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ─── API AGENT WHATSAPP (n8n lit produits / commandes en DB) ───────────────────
# Header : Authorization: Bearer <secret>
AGENT_API_SECRET="change-me-agent-secret"

# ─── WHATSAPP ─────────────────────────────────────────────────────────────────
# Format international sans +, ex: 224620123456 (Guinée)
NEXT_PUBLIC_WHATSAPP_NUMBER="224620000000"

# ─── CONTACT BOUTIQUE (appels & e-mail affichés sur le site) ───────────────────
# Format affiché : +224 629 40 30 19 — utilisé pour les liens tel:
NEXT_PUBLIC_CONTACT_PHONE="+224 629 40 30 19"
NEXT_PUBLIC_CONTACT_EMAIL="contact@lovepiment.gn"

# ─── RÉSEAUX SOCIAUX ──────────────────────────────────────────────────────────
NEXT_PUBLIC_FACEBOOK_PAGE_URL="https://www.facebook.com/lovepiment"

# ─── META (Facebook) PIXEL ────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID="[META_PIXEL_ID]"

# ─── GOOGLE ANALYTICS 4 ──────────────────────────────────────────────────────
# 1) analytics.google.com → Admin → Flux de données → ID de mesure (G-XXXXXXXX)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# 2) Admin → Détails de la propriété → ID de propriété (numérique, ex: 123456789)
GA4_PROPERTY_ID="123456789"
# 3) Google Cloud → Compte de service + activer "Google Analytics Data API"
# 4) GA4 → Admin → Accès à la propriété → Ajouter l'e-mail du compte de service (Lecteur)
GOOGLE_ANALYTICS_CLIENT_EMAIL="analytics@mon-projet.iam.gserviceaccount.com"
# Clé privée du JSON (gardez les \n ou mettez la clé entre guillemets sur une ligne)
GOOGLE_ANALYTICS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── E-MAIL (SMTP — reset MDP, contact, digest admin, bienvenue livreur) ───────
# Sans SMTP en local : les e-mails sont affichés dans la console du serveur.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="votre-email@gmail.com"
SMTP_PASS="mot-de-passe-application"
MAIL_FROM="Love Piment& <noreply@lovepiment.gn>"
ADMIN_EMAIL="admin@lovepiment.gn"
CONTACT_EMAIL="contact@lovepiment.gn"
CRON_SECRET="change-me-cron-secret"
CRON_TIMEZONE="Africa/Conakry"

# ─── OAUTH (connexion Google / Facebook / Apple — optionnel) ─────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# FACEBOOK_APP_ID=""
# FACEBOOK_APP_SECRET=""
# APPLE_CLIENT_ID=""
# APPLE_TEAM_ID=""
# APPLE_KEY_ID=""
# APPLE_PRIVATE_KEY=""

# ─── CLOUDINARY (images admin — fichiers hébergés, URLs seules en base) ───────
# Dashboard : https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME="[CLOUDINARY_CLOUD_NAME]"
CLOUDINARY_API_KEY="[CLOUDINARY_API_KEY]"
CLOUDINARY_API_SECRET="[CLOUDINARY_API_SECRET]"
# Préfixe des dossiers (ex. lovepimente/products, lovepimente/apropos)
# CLOUDINARY_FOLDER_PREFIX="lovepimente"

# ─── APP ──────────────────────────────────────────────────────────────────────
# Si le port 3000 est pris (autre projet Next.js), utiliser 3001
PORT=3001
# URL publique du site — Orange Money exige HTTPS en production (webhook + retour paiement)
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NODE_ENV="development"

# ─── AUTH (sessions admin + client) ───────────────────────────────────────────
# Obligatoire en local : min. 16 caractères — ne changez pas en prod sans prévoir une déconnexion globale
AUTH_SECRET="change-me-min-16-chars"

# ─── ADMIN (compte seed — npm run db:ensure-admin) ────────────────────────────
# Défaut : admin@lovepiment.gn / LovePiment2026!
# ADMIN_EMAIL="admin@lovepiment.gn"
# ADMIN_PASSWORD="LovePiment2026!"

# ─── CLIENT DÉMO (seed — npm run db:seed) ───────────────────────────────────
# Défaut : CONTACT_EMAIL ou client@lovepiment.gn / Client2026!
# DEMO_CUSTOMER_EMAIL="client@lovepiment.gn"
# DEMO_CUSTOMER_PASSWORD="Client2026!"

# ─── LIVREUR DÉMO (seed — npm run db:seed) ───────────────────────────────────
# Défaut : livreur@lovepiment.gn / Livreur2026!
# DEMO_COURIER_EMAIL="livreur@lovepiment.gn"
# DEMO_COURIER_PASSWORD="Livreur2026!"
