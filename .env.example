# ─── BASE DE DONNÉES ──────────────────────────────────────────────────────────
# Local (Docker) : npm run db:up puis utiliser ces URLs
DATABASE_URL="postgresql://postgres:password@localhost:5432/kabishop_dev"
DIRECT_URL="postgresql://postgres:password@localhost:5432/kabishop_dev"
# Production (Supabase) :
# DATABASE_URL = Transaction pooler (port 6543)
# DIRECT_URL   = Session pooler (port 5432) — même hôte pooler, PAS db.xxx.supabase.co si injoignable
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# ─── CINETPAY (Paiement Mobile Money + Carte) ─────────────────────────────────
CINETPAY_API_KEY="[CINETPAY_API_KEY]"
CINETPAY_SITE_ID="[CINETPAY_SITE_ID]"

# ─── IA (assistant shopping — Gemini) ─────────────────────────────────────────
# Clé gratuite : https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# ─── API AGENT WHATSAPP (n8n lit produits / commandes en DB) ───────────────────
# Header : Authorization: Bearer <secret>
AGENT_API_SECRET="change-me-agent-secret"

# ─── WHATSAPP ─────────────────────────────────────────────────────────────────
# Format international sans +, ex: 224620123456 (Guinée)
NEXT_PUBLIC_WHATSAPP_NUMBER="224620000000"

# ─── RÉSEAUX SOCIAUX ──────────────────────────────────────────────────────────
NEXT_PUBLIC_FACEBOOK_PAGE_URL="https://www.facebook.com/kabishop"

# ─── META (Facebook) PIXEL ────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID="[META_PIXEL_ID]"

# ─── GOOGLE ANALYTICS 4 ──────────────────────────────────────────────────────
# 1) analytics.google.com → Admin → Flux de données → ID de mesure (G-XXXXXXXX)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# 2) Admin → Détails de la propriété → ID de propriété (numérique, ex: 123456789)
GA4_PROPERTY_ID="123456789"
# 3) Google Cloud → Compte de service + activer "Google Analytics Data API"
# 4) GA4 → Admin → Accès à la propriété → Ajouter l'e-mail du compte de service (Lecteur)
GOOGLE_ANALYTICS_CLIENT_EMAIL="analytics@mon-projet.iam.gserviceaccount.com"
# Clé privée du JSON (gardez les \n ou mettez la clé entre guillemets sur une ligne)
GOOGLE_ANALYTICS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── SENTRY (Monitoring erreurs) ──────────────────────────────────────────────
SENTRY_DSN="[SENTRY_DSN]"
NEXT_PUBLIC_SENTRY_DSN="[SENTRY_DSN_PUBLIC]"

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── AUTH (sessions admin + client) ───────────────────────────────────────────
# Obligatoire en local : min. 16 caractères — ne changez pas en prod sans prévoir une déconnexion globale
AUTH_SECRET="change-me-min-16-chars"

# ─── ADMIN (compte seed — npm run db:ensure-admin) ────────────────────────────
# Défaut : admin@kabishop.com / KabiShop2026!
# ADMIN_EMAIL="admin@kabishop.com"
# ADMIN_PASSWORD="KabiShop2026!"

# ─── CLIENT DÉMO (seed — npm run db:seed) ───────────────────────────────────
# Défaut : CONTACT_EMAIL ou client@kabishop.com / Client2026!
# DEMO_CUSTOMER_EMAIL="client@kabishop.com"
# DEMO_CUSTOMER_PASSWORD="Client2026!"

# ─── LIVREUR DÉMO (seed — npm run db:seed) ───────────────────────────────────
# Défaut : livreur@kabishop.com / Livreur2026!
# DEMO_COURIER_EMAIL="livreur@kabishop.com"
# DEMO_COURIER_PASSWORD="Livreur2026!"

# ─── E-MAIL (SMTP — bienvenue livreur, contact, digest admin) ────────────────
# Sans SMTP en local : les e-mails sont affichés dans la console du serveur (dev).
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="votre-email@gmail.com"
# SMTP_PASS="mot-de-passe-application"
# MAIL_FROM="KabiShop <noreply@kabishop.com>"
