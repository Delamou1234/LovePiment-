{
  "name": "love-piment",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3001",
    "dev:turbo": "next dev --turbopack -p 3001",
    "dev:clean": "npm run clean && next dev --webpack",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "prisma generate && prisma db push --accept-data-loss && npm run db:ensure-admin",
    "db:ensure-admin": "npx tsx prisma/run-ensure-admin.ts",
    "db:reset-admin": "npx tsx prisma/reset-admin-password.ts",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:setup": "npm run db:push && npm run db:seed",
    "db:migrate": "prisma migrate deploy && npm run db:ensure-admin",
    "db:health": "npx tsx scripts/db-health.ts",
    "db:check-courier": "npx tsx scripts/db-check-courier.ts",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "verify:pwa": "node scripts/verify-pwa.mjs",
    "verify:orange-money": "node scripts/verify-orange-money.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@google-analytics/data": "^6.1.0",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "nodemailer": "^9.0.1",
    "pg": "^8.16.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "react-qr-code": "^2.2.0",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
