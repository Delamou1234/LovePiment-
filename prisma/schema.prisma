generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum OrderStatus {
  EN_ATTENTE
  PAYEE
  EN_PREPARATION
  EXPEDIEE
  LIVREE
  ANNULEE
}

enum PaymentMethod {
  CINETPAY
  PAIEMENT_LIVRAISON
}

enum PaymentStatus {
  EN_ATTENTE
  REUSSIE
  ECHOUEE
  REMBOURSEE
}

enum EventType {
  PAGE_VIEW
  PRODUCT_VIEW
  ADD_TO_CART
  CHECKOUT_START
  ORDER_PLACED
}

enum TrackingEventType {
  STATUT
  NOTIFICATION
  TRANSPORTEUR
  SATISFACTION
}

enum OrderSatisfaction {
  SATISFAIT
  NON_SATISFAIT
}

enum MessageSenderRole {
  CLIENT
  VENDEUR
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  VOICE
}

enum ChatParticipantRole {
  CLIENT
  VENDEUR
}

enum CallSignalType {
  OFFER
  ANSWER
  ICE
  END
  REJECT
}

enum ContactSubject {
  GENERAL
  COMMANDE
  PRODUIT
  PARTENARIAT
  AUTRE
}

enum ContactMessageStatus {
  NOUVEAU
  LU
  TRAITE
}

enum CouponType {
  POURCENT
  MONTANT_FIXE
}

enum ReviewStatus {
  EN_ATTENTE
  APPROUVE
  REFUSE
}

// ─── CATEGORY ────────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  nom       String
  slug      String    @unique
  image     String?
  actif     Boolean   @default(true)
  parentId  String?   @map("parent_id")
  parent    Category? @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  produits  Product[]

  @@index([parentId])
  @@map("categories")
}

// ─── PRODUCT ─────────────────────────────────────────────────────────────────

model Product {
  id          String    @id @default(cuid())
  nom         String
  slug        String    @unique
  marque      String?
  description String?
  prix        Decimal   @db.Decimal(10, 0)
  prixPromo   Decimal?  @db.Decimal(10, 0) @map("prix_promo")
  promoDebut  DateTime? @map("promo_debut")
  promoFin    DateTime? @map("promo_fin")
  images      String[]
  actif       Boolean   @default(true)
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  categorieId String    @map("categorie_id")
  categorie   Category  @relation(fields: [categorieId], references: [id])

  variantes   ProductVariant[]
  analyticsEvents AnalyticsEvent[]
  wishlistItems WishlistItem[]
  avis            ProductReview[]

  @@index([nom])
  @@map("products")
}

// ─── PRODUCT VARIANT ─────────────────────────────────────────────────────────

model ProductVariant {
  id         String  @id @default(cuid())
  taille     String?
  couleur    String?
  capacite   String?
  stock      Int     @default(0)
  sku        String? @unique
  codeBarre  String? @unique @map("code_barre")
  prix       Decimal? @db.Decimal(10, 0)

  productId String  @map("product_id")
  produit   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItems OrderItem[]

  @@map("product_variants")
}

// ─── CARRIER ─────────────────────────────────────────────────────────────────

model Carrier {
  id             String   @id @default(cuid())
  nom            String
  slug           String   @unique
  telephone      String?
  actif          Boolean  @default(true)
  delaiMinHeures Int      @default(24) @map("delai_min_heures")
  delaiMaxHeures Int      @default(48) @map("delai_max_heures")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  commandes      Order[]

  @@map("carriers")
}

// ─── ORDER ───────────────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(cuid())
  customerId      String?       @map("customer_id")
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  // Infos client
  clientNom       String        @map("client_nom")
  clientTelephone String        @map("client_telephone")
  clientAdresse   String        @map("client_adresse")
  clientVille     String        @map("client_ville")
  clientLatitude  Decimal?      @db.Decimal(10, 7) @map("client_latitude")
  clientLongitude Decimal?      @db.Decimal(10, 7) @map("client_longitude")
  // Commande
  statut          OrderStatus   @default(EN_ATTENTE)
  modePaiement    PaymentMethod @map("mode_paiement")
  statutPaiement  PaymentStatus @default(EN_ATTENTE) @map("statut_paiement")
  sousTotal       Decimal?      @db.Decimal(10, 0) @map("sous_total")
  fraisLivraison  Decimal?      @db.Decimal(10, 0) @map("frais_livraison")
  remiseCoupon    Decimal       @default(0) @db.Decimal(10, 0) @map("remise_coupon")
  remisePoints    Decimal       @default(0) @db.Decimal(10, 0) @map("remise_points")
  remiseParrainage Decimal      @default(0) @db.Decimal(10, 0) @map("remise_parrainage")
  pointsUtilises  Int           @default(0) @map("points_utilises")
  pointsGagnes    Int           @default(0) @map("points_gagnes")
  pointsCredites  Boolean       @default(false) @map("points_credites")
  montantTotal    Decimal       @db.Decimal(10, 0) @map("montant_total")
  couponId        String?       @map("coupon_id")
  coupon          Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  codeParrainageUtilise String? @map("code_parrainage_utilise")
  // Suivi livraison
  suiviToken      String        @unique @default(cuid()) @map("suivi_token")
  livraisonNavToken String      @unique @default(cuid()) @map("livraison_nav_token")
  numeroSuivi     String?       @map("numero_suivi")
  livraisonEstimee DateTime?    @map("livraison_estimee")
  livreeLe        DateTime?     @map("livree_le")
  carrierId       String?       @map("carrier_id")
  carrier         Carrier?      @relation(fields: [carrierId], references: [id], onDelete: SetNull)
  courierId       String?       @map("courier_id")
  courier         Courier?      @relation(fields: [courierId], references: [id], onDelete: SetNull)
  deliveryRunId   String?       @map("delivery_run_id")
  deliveryRun     DeliveryRun?  @relation(fields: [deliveryRunId], references: [id], onDelete: SetNull)
  ordreLivraison  Int?          @map("ordre_livraison")
  assignedAt      DateTime?     @map("assigned_at")
  livreurPaiementRecu      Boolean?  @map("livreur_paiement_recu")
  livreurPaiementDeclareAt DateTime? @map("livreur_paiement_declare_at")
  penaliteLivreurGn        Decimal?  @db.Decimal(10, 0) @map("penalite_livreur_gn")
  // Référence CinetPay (si applicable)
  cinetpayTxId    String?       @unique @map("cinetpay_tx_id")
  // Notes internes
  notes           String?
  // Avis client après livraison
  satisfactionStatut       OrderSatisfaction? @map("satisfaction_statut")
  satisfactionCommentaire  String?            @map("satisfaction_commentaire")
  satisfactionLe           DateTime?          @map("satisfaction_le")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  items           OrderItem[]
  trackingEvents  OrderTrackingEvent[]
  avis            ProductReview[]

  @@index([statut])
  @@index([suiviToken])
  @@index([livraisonNavToken])
  @@index([satisfactionStatut])
  @@index([customerId])
  @@index([courierId])
  @@index([deliveryRunId])
  @@index([clientNom])
  @@index([clientTelephone])
  @@map("orders")
}

// ─── TOURNÉE DE LIVRAISON (plusieurs commandes, un livreur) ─────────────────

enum DeliveryRunStatus {
  PLANIFIEE
  EN_COURS
  TERMINEE
  ANNULEE
}

model DeliveryRun {
  id         String            @id @default(cuid())
  label      String?
  courierId  String?           @map("courier_id")
  courier    Courier?          @relation(fields: [courierId], references: [id], onDelete: SetNull)
  statut     DeliveryRunStatus @default(PLANIFIEE)
  assignedAt DateTime?         @map("assigned_at")
  montantTotalGn   Decimal?    @db.Decimal(12, 0) @map("montant_total_gn")
  montantEspecesGn Decimal?    @db.Decimal(12, 0) @map("montant_especes_gn")
  notesAdmin String?           @map("notes_admin")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  commandes  Order[]

  @@index([courierId])
  @@index([statut])
  @@map("delivery_runs")
}

// ─── LIVREUR (courier) ───────────────────────────────────────────────────────

enum CourierVehicleType {
  MOTO
  VOITURE
  VELO
  AUTRE
}

model Courier {
  id                String              @id @default(cuid())
  email             String              @unique
  passwordHash      String              @map("password_hash")
  nom               String
  telephone         String
  whatsapp          String?
  typeEngin         CourierVehicleType  @default(MOTO) @map("type_engin")
  immatriculation   String?
  numeroCni         String?             @map("numero_cni")
  quartierBase      String?             @map("quartier_base")
  commune           String?
  contactUrgenceNom String?             @map("contact_urgence_nom")
  contactUrgenceTel String?             @map("contact_urgence_tel")
  permisConduire    String?             @map("permis_conduire")
  photoUrl          String?             @map("photo_url")
  verifie           Boolean             @default(false)
  actif             Boolean             @default(true)
  notesAdmin        String?             @map("notes_admin")
  penalitesCumuleesGn Decimal           @default(0) @db.Decimal(12, 0) @map("penalites_cumulees_gn")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  commandes         Order[]
  tournees          DeliveryRun[]

  @@index([actif])
  @@map("couriers")
}

// ─── ORDER TRACKING EVENT ────────────────────────────────────────────────────

model OrderTrackingEvent {
  id        String            @id @default(cuid())
  type      TrackingEventType @default(STATUT)
  statut    OrderStatus?
  message   String
  notifier  Boolean           @default(false) @map("notifier_client")

  orderId   String            @map("order_id")
  order     Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime          @default(now()) @map("created_at")

  @@index([orderId, createdAt])
  @@map("order_tracking_events")
}

// ─── ORDER ITEM ───────────────────────────────────────────────────────────────

model OrderItem {
  id           String         @id @default(cuid())
  quantite     Int
  prixUnitaire Decimal        @db.Decimal(10, 0) @map("prix_unitaire")

  orderId      String         @map("order_id")
  ordre        Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId    String         @map("variant_id")
  variante     ProductVariant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ─── STORE SETTINGS ──────────────────────────────────────────────────────────

model StoreSettings {
  id              String  @id @default(cuid())
  nomBoutique     String  @default("Love Piment&") @map("nom_boutique")
  logoUrl         String? @map("logo_url")
  telephone       String?
  adresse         String?
  ville           String? @default("Conakry")
  pays            String? @default("Guinée")
  whatsappNumber  String? @map("whatsapp_number")
  facebookUrl     String? @map("facebook_url")
  instagramUrl    String? @map("instagram_url")
  email           String?
  metaDescription String? @map("meta_description")
  parrainageActif Boolean @default(true) @map("parrainage_actif")
  appelsActifs    Boolean @default(true) @map("appels_actifs")
  newsletterActif        Boolean @default(true) @map("newsletter_actif")
  newsletterTitre        String  @default("Offre de bienvenue !") @map("newsletter_titre")
  newsletterDescription  String? @map("newsletter_description")
  newsletterImageUrl     String? @map("newsletter_image_url")
  newsletterRemisePct    Int     @default(10) @map("newsletter_remise_pct")
  newsletterCouponCode   String? @default("BIENVENUE10") @map("newsletter_coupon_code")
  livraisonTarifConakry      Int     @default(15000) @map("livraison_tarif_conakry")
  livraisonTarifHorsConakry  Int     @default(25000) @map("livraison_tarif_hors_conakry")
  livraisonSeuilGratuit      Int     @default(500000) @map("livraison_seuil_gratuit")
  livraisonVilleParDefaut    String  @default("Conakry") @map("livraison_ville_par_defaut")
  livraisonGratuiteActive    Boolean @default(true) @map("livraison_gratuite_active")
  livraisonDelaiLabel        String? @default("24–48 h") @map("livraison_delai_label")
  aproposHeroKicker          String? @map("apropos_hero_kicker")
  aproposHeroTitre           String? @map("apropos_hero_titre")
  aproposHeroAccent          String? @map("apropos_hero_accent")
  aproposHeroTexte           String? @map("apropos_hero_texte") @db.Text
  aproposHeroImageUrl        String? @map("apropos_hero_image_url")
  aproposMissionTitre        String? @map("apropos_mission_titre")
  aproposMissionTexte        String? @map("apropos_mission_texte") @db.Text
  aproposHistoireTitre       String? @map("apropos_histoire_titre")
  aproposHistoireTexte       String? @map("apropos_histoire_texte") @db.Text
  aproposChiffres            Json?   @map("apropos_chiffres")
  aproposValeurs             Json?   @map("apropos_valeurs")
  aproposCtaTitre            String? @map("apropos_cta_titre")
  aproposCtaTexte            String? @map("apropos_cta_texte") @db.Text
  aproposMetaDescription     String? @map("apropos_meta_description") @db.Text
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("store_settings")
}

// ─── ADMIN ───────────────────────────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  nom          String   @default("Administrateur")
  actif        Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_users")
}

// ─── ANALYTICS EVENT ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String    @id @default(cuid())
  type      EventType
  path      String?
  sessionId String?   @map("session_id")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  productId String?   @map("product_id")
  produit   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
  @@index([productId])
  @@map("analytics_events")
}

// ─── CUSTOMER (auth checkout) ────────────────────────────────────────────────

model Customer {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String?  @map("password_hash")
  googleId        String?  @unique @map("google_id")
  facebookId      String?  @unique @map("facebook_id")
  appleId         String?  @unique @map("apple_id")
  avatarUrl       String?  @map("avatar_url")
  nom             String
  telephone       String?
  adressePreferee String?  @map("adresse_preferee")
  villePreferee   String?  @map("ville_preferee")
  avatarCouleur   String?  @default("olive") @map("avatar_couleur")
  beautyProfile   Json?    @map("beauty_profile")
  pointsFidelite  Int      @default(0) @map("points_fidelite")
  codeParrainage  String?  @unique @map("code_parrainage")
  parrainId       String?  @map("parrain_id")
  parrain         Customer?  @relation("Parrainage", fields: [parrainId], references: [id], onDelete: SetNull)
  filleuls        Customer[] @relation("Parrainage")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  commandes           Order[]
  adresses            CustomerAddress[]
  wishlist            WishlistItem[]
  avis                ProductReview[]
  passwordResetTokens PasswordResetToken[]

  @@index([nom])
  @@index([email])
  @@map("customers")
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  codeHash   String    @unique @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  label      String?
  adresse    String
  ville      String   @default("Conakry")
  telephone  String?
  parDefaut  Boolean  @default(false) @map("par_defaut")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model WishlistItem {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now()) @map("created_at")

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  productId  String   @map("product_id")
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("wishlist_items")
}

// ─── MARKETING ───────────────────────────────────────────────────────────────

model Coupon {
  id              String     @id @default(cuid())
  code            String     @unique
  type            CouponType
  valeur          Decimal    @db.Decimal(10, 0)
  minCommande     Decimal?   @db.Decimal(10, 0) @map("min_commande")
  maxUtilisations Int?       @map("max_utilisations")
  utilisations    Int        @default(0)
  actif           Boolean    @default(true)
  debut           DateTime?
  fin             DateTime?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  commandes       Order[]

  @@map("coupons")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("homepage")
  actif     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("newsletter_subscribers")
}

model FlashSale {
  id          String   @id @default(cuid())
  titre       String
  slug        String   @unique
  description String?
  debut       DateTime
  fin         DateTime
  actif       Boolean  @default(true)
  productIds  String[] @map("product_ids")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("flash_sales")
}

model ProductReview {
  id           String       @id @default(cuid())
  note         Int
  commentaire  String
  photos       String[]     @default([])
  achatVerifie Boolean      @default(true) @map("achat_verifie")
  statut       ReviewStatus @default(APPROUVE)
  modereLe     DateTime?    @map("modere_le")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  productId    String       @map("product_id")
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerId   String       @map("customer_id")
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderId      String       @map("order_id")
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, productId])
  @@index([productId, statut])
  @@index([customerId])
  @@map("product_reviews")
}

// ─── MESSAGERIE ──────────────────────────────────────────────────────────────

model Conversation {
  id               String    @id @default(cuid())
  clientSessionId  String    @map("client_session_id")
  clientUserId     String?   @map("client_user_id")
  clientNom        String    @map("client_nom")
  clientTelephone  String?   @map("client_telephone")
  sujet            String?
  orderId          String?   @map("order_id")
  dernierMessage   String?   @map("dernier_message")
  dernierMessageAt DateTime? @map("dernier_message_at")
  nonLuVendeur     Int       @default(0) @map("non_lu_vendeur")
  nonLuClient      Int       @default(0) @map("non_lu_client")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  messages         ChatMessage[]
  callSignals      ChatCallSignal[]

  @@index([clientSessionId])
  @@index([dernierMessageAt])
  @@map("conversations")
}

model ChatMessage {
  id             String            @id @default(cuid())
  conversationId String            @map("conversation_id")
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderRole     MessageSenderRole @map("sender_role")
  type           MessageType       @default(TEXT)
  contenu        String?
  fichierUrl     String?           @map("fichier_url")
  fichierNom     String?           @map("fichier_nom")
  fichierTaille  Int?              @map("fichier_taille")
  dureeMs        Int?              @map("duree_ms")
  luLe           DateTime?         @map("lu_le")
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

model ChatPresence {
  id             String              @id @default(cuid())
  conversationId String              @map("conversation_id")
  role           ChatParticipantRole
  participantId  String              @map("participant_id")
  lastSeenAt     DateTime            @default(now()) @map("last_seen_at")
  isTyping       Boolean             @default(false) @map("is_typing")

  @@unique([conversationId, role, participantId])
  @@index([conversationId])
  @@map("chat_presences")
}

model ChatCallSignal {
  id             String            @id @default(cuid())
  conversationId String            @map("conversation_id")
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  fromRole       MessageSenderRole   @map("from_role")
  type           CallSignalType
  payload        String            @default("{}")
  createdAt      DateTime          @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("chat_call_signals")
}

// ─── CONTACT ─────────────────────────────────────────────────────────────────

model ContactMessage {
  id         String               @id @default(cuid())
  nom        String
  email      String
  telephone  String?
  sujet      ContactSubject
  message    String
  statut     ContactMessageStatus @default(NOUVEAU)
  customerId String?              @map("customer_id")
  createdAt  DateTime             @default(now()) @map("created_at")
  traiteLe   DateTime?            @map("traite_le")

  @@index([statut])
  @@index([createdAt])
  @@map("contact_messages")
}
