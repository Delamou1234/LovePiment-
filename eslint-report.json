\n              <div>\r\n                <label className=\"text-xs font-semibold text-zinc-600\">D├®placer les produits vers</label>\r\n                <select\r\n                  value={reassignToId}\r\n                  onChange={(e) => setReassignToId(e.target.value)}\r\n                  className=\"mt-1 w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm\"\r\n                >\r\n                  {categories\r\n                    .filter((cat) => cat.id !== deleteTarget.id)\r\n                    .map((cat) => (\r\n                      <option key={cat.id} value={cat.id}>\r\n                        {cat.parentId ? `Ôå│ ${cat.nom}` : cat.nom}\r\n                      </option>\r\n                    ))}\r\n                </select>\r\n              </div>\r\n              {deleteError && <p className=\"text-sm text-red-600\">{deleteError}</p>}\r\n            </div>\r\n            <div className=\"flex justify-end gap-2 border-t border-zinc-100 px-6 py-4\">\r\n              <Button variant=\"outline\" onClick={() => setDeleteTarget(null)}>\r\n                Annuler\r\n              </Button>\r\n              <Button\r\n                onClick={confirmerSuppressionAvecReassign}\r\n                disabled={deleting}\r\n                className=\"bg-red-600 hover:bg-red-700 text-white\"\r\n              >\r\n                {deleting ? <Loader2 className=\"mr-2 h-4 w-4 animate-spin\" /> : null}\r\n                D├®placer et supprimer\r\n              </Button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n\r\n      {formOpen && (\r\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4\">\r\n          <div className=\"w-full max-w-lg rounded-2xl bg-white shadow-xl\">\r\n            <div className=\"flex items-center justify-between border-b border-zinc-100 px-6 py-4\">\r\n              <h2 className=\"font-bold text-zinc-900\">\r\n                {editingId ? 'Modifier la cat├®gorie' : 'Nouvelle cat├®gorie'}\r\n              </h2>\r\n              <button type=\"button\" onClick={() => setFormOpen(false)} className=\"p-1 hover:bg-zinc-100 rounded-lg\">\r\n                <X className=\"h-5 w-5 text-zinc-500\" />\r\n              </button>\r\n            </div>\r\n\r\n            <div className=\"px-6 py-5 space-y-4\">\r\n              <div>\r\n                <label className=\"text-xs font-semibold text-zinc-600\">Nom *</label>\r\n                <input\r\n                  value={form.nom}\r\n                  onChange={(e) => {\r\n                    const nom = e.target.value;\r\n                    setForm((prev) => ({\r\n                      ...prev,\r\n                      nom,\r\n                      slug: editingId ? prev.slug : genererSlug(nom),\r\n                    }));\r\n                  }}\r\n                  placeholder=\"Ex: Parfums\"\r\n                  className=\"mt-1 w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm\"\r\n                />\r\n              </div>\r\n\r\n              <div>\r\n                <label className=\"text-xs font-semibold text-zinc-600\">Slug (URL)</label>\r\n                <input\r\n                  value={form.slug}\r\n                  onChange={(e) => setForm({ ...form, slug: e.target.value })}\r\n                  placeholder=\"Auto-g├®n├®r├® si vide ÔÇö ex: parfums\"\r\n                  className=\"mt-1 w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm font-mono\"\r\n                />\r\n              </div>\r\n\r\n              <div>\r\n                <label className=\"text-xs font-semibold text-zinc-600\">Image (URL)</label>\r\n                <input\r\n                  value={form.image}\r\n                  onChange={(e) => setForm({ ...form, image: e.target.value })}\r\n                  placeholder=\"https://ÔÇª\"\r\n                  className=\"mt-1 w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm\"\r\n                />\r\n              </div>\r\n\r\n              <div>\r\n                <label className=\"text-xs font-semibold text-zinc-600\">Cat├®gorie parente</label>\r\n                <select\r\n                  value={form.parentId}\r\n                  onChange={(e) => setForm({ ...form, parentId: e.target.value })}\r\n                  className=\"mt-1 w-full rounded-lg border border-zinc-200 px-3 py-2 text-sm\"\r\n                >\r\n                  <option value=\"\">Aucune (cat├®gorie principale)</option>\r\n                  {parentOptions.map((c) => (\r\n                    <option key={c.id} value={c.id}>\r\n                      {c.nom}\r\n                    </option>\r\n                  ))}\r\n                </select>\r\n              </div>\r\n\r\n              <label className=\"flex items-center gap-2 text-sm text-zinc-700\">\r\n                <input\r\n                  type=\"checkbox\"\r\n                  checked={form.actif}\r\n                  onChange={(e) => setForm({ ...form, actif: e.target.checked })}\r\n                  className=\"rounded border-zinc-300\"\r\n                />\r\n                Cat├®gorie active (visible boutique)\r\n              </label>\r\n\r\n              {error && <p className=\"text-sm text-red-600\">{error}</p>}\r\n            </div>\r\n\r\n            <div className=\"flex justify-end gap-2 border-t border-zinc-100 px-6 py-4\">\r\n              <Button variant=\"outline\" onClick={() => setFormOpen(false)}>\r\n                Annuler\r\n              </Button>\r\n              <Button onClick={save} disabled={saving} className=\"btn-primary\">\r\n                {saving ? <Loader2 className=\"h-4 w-4 animate-spin mr-2\" /> : null}\r\n                {editingId ? 'Enregistrer' : 'Cr├®er'}\r\n              </Button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Sam\\Desktop\\kabishop - Copie\\src\\app\\admin\\clients\\page.tsx",