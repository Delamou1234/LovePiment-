r\n  RefreshCw,\r\n  TrendingUp,\r\n  Users,\r\n  LineChart,\r\n  LayoutDashboard,\r\n} from 'lucide-react';\r\nimport { Button } from '@/components/ui/button';\r\n\r\ntype BiRapport = {\r\n  periode: string;\r\n  genereLe: string;\r\n  chiffreAffaires: {\r\n    total: number;\r\n    commandes: number;\r\n    panierMoyen: number;\r\n    evolutionPct: number | null;\r\n    parJour: { date: string; montant: number; commandes: number }[];\r\n    parMois: { mois: string; montant: number; commandes: number }[];\r\n  };\r\n  topProduits: {\r\n    productId: string;\r\n    nom: string;\r\n    slug: string;\r\n    image: string | null;\r\n    quantiteVendue: number;\r\n    chiffreAffaires: number;\r\n  }[];\r\n  clients: {\r\n    inscrits: number;\r\n    commandesInvite: number;\r\n    clientsActifs: number;\r\n    tauxFidelite: number;\r\n    panierMoyen: number;\r\n    topClients: {\r\n      id: string | null;\r\n      nom: string;\r\n      email: string | null;\r\n      commandes: number;\r\n      totalDepense: number;\r\n    }[];\r\n    repartitionVilles: { ville: string; commandes: number }[];\r\n  };\r\n  previsions: {\r\n    moyenneJournaliere: number;\r\n    tendancePct: number | null;\r\n    prevision7j: number;\r\n    prevision30j: number;\r\n    historique7j: { date: string; reel: number; prevision: number }[];\r\n  };\r\n  powerBi: {\r\n    configure: boolean;\r\n    embedUrl: string | null;\r\n    reportUrl: string | null;\r\n  };\r\n};\r\n\r\nconst PERIODES = [\r\n  { value: '7j', label: '7 jours' },\r\n  { value: '30j', label: '30 jours' },\r\n  { value: '90j', label: '90 jours' },\r\n  { value: '12m', label: '12 mois' },\r\n] as const;\r\n\r\nfunction formatGn(n: number) {\r\n  return n.toLocaleString('fr-FR') + ' GN';\r\n}\r\n\r\nfunction formatPct(n: number | null) {\r\n  if (n == null) return 'ÔÇö';\r\n  const sign = n > 0 ? '+' : '';\r\n  return `${sign}${n} %`;\r\n}\r\n\r\nfunction BarChart({\r\n  data,\r\n  valueKey,\r\n  labelKey,\r\n  maxValue,\r\n}: {\r\n  data: { [key: string]: string | number }[];\r\n  valueKey: string;\r\n  labelKey: string;\r\n  maxValue: number;\r\n}) {\r\n  return (\r\n    <div className=\"space-y-2\">\r\n      {data.map((row) => {\r\n        const val = Number(row[valueKey]);\r\n        const label = String(row[labelKey]);\r\n        return (\r\n          <div key={label} className=\"flex items-center gap-3 text-sm\">\r\n            <span className=\"w-16 shrink-0 text-zinc-500 text-xs tabular-nums\">\r\n              {label.length > 7 ? label.slice(5) : label}\r\n            </span>\r\n            <div className=\"flex-1 h-2.5 bg-zinc-100 rounded-full overflow-hidden\">\r\n              <div\r\n                className=\"h-full bg-[#9B1B2E] rounded-full transition-all duration-500\"\r\n                style={{ width: `${maxValue > 0 ? (val / maxValue) * 100 : 0}%` }}\r\n              />\r\n            </div>\r\n            <span className=\"w-24 text-right font-medium text-xs tabular-nums shrink-0\">\r\n              {typeof val === 'number' && val > 999 ? formatGn(val) : val}\r\n            </span>\r\n          </div>\r\n        );\r\n      })}\r\n      {data.length === 0 && (\r\n        <p className=\"text-sm text-zinc-400 py-4 text-center\">Pas de donn├®es sur cette p├®riode.</p>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default function AdminBiPage() {\r\n  const [periode, setPeriode] = useState<(typeof PERIODES)[number]['value']>('30j');\r\n  const [rapport, setRapport] = useState<BiRapport | null>(null);\r\n  const [loading, setLoading] = useState(true);\r\n\r\n  const load = useCallback(async () => {\r\n    setLoading(true);\r\n    try {\r\n      const res = await fetch(`/api/admin/bi?periode=${periode}`);\r\n      if (res.ok) {\r\n        const data = await res.json();\r\n        setRapport(data.rapport);\r\n      }\r\n    } finally {\r\n      setLoading(false);\r\n    }\r\n  }, [periode]);\r\n\r\n  useEffect(() => {\r\n    load();\r\n  }, [load]);\r\n\r\n  const maxCaJour = Math.max(...(rapport?.chiffreAffaires.parJour.map((d) => d.montant) ?? [1]), 1);\r\n  const maxCaMois = Math.max(...(rapport?.chiffreAffaires.parMois.map((d) => d.montant) ?? [1]), 1);\r\n  const maxPrev = Math.max(\r\n    ...(rapport?.previsions.historique7j.flatMap((d) => [d.reel, d.prevision]) ?? [1]),\r\n    1,\r\n  );\r\n\r\n  return (\r\n    <div className=\"space-y-8 max-w-7xl\">\r\n      <div className=\"flex flex-wrap items-start justify-between gap-4\">\r\n        <div>\r\n          <p className=\"text-[10px] font-bold uppercase tracking-widest text-[#9B1B2E] mb-1\">\r\n            Business Intelligence\r\n          </p>\r\n          <h1 className=\"text-2xl md:text-3xl font-bold text-zinc-900 flex items-center gap-2\">\r\n            <LayoutDashboard className=\"h-7 w-7 text-[#9B1B2E]\" />\r\n            Tableaux de bord BI\r\n          </h1>\r\n          <p className=\"text-sm text-zinc-500 mt-1\">\r\n            Chiffre d&apos;affaires, ventes, clients et pr├®visions ÔÇö donn├®es live depuis PostgreSQL.\r\n          </p>\r\n        </div>\r\n        <div className=\"flex gap-2 items-center\">\r\n          <select\r\n            className=\"input-shop py-2 text-sm min-w-[120px]\"\r\n            value={periode}\r\n            onChange={(e) => setPeriode(e.target.value as typeof periode)}\r\n          >\r\n            {PERIODES.map((p) => (\r\n              <option key={p.value} value={p.value}>\r\n                {p.label}\r\n              </option>\r\n            ))}\r\n          </select>\r\n          <Button variant=\"outline\" size=\"sm\" onClick={load} disabled={loading}>\r\n            <RefreshCw className={`h-4 w-4 mr-2 ${loading ? 'animate-spin' : ''}`} />\r\n            Actualiser\r\n          </Button>\r\n        </div>\r\n      </div>\r\n\r\n      {loading || !rapport ? (\r\n        <div className=\"flex justify-center py-24\">\r\n          <Loader2 className=\"h-8 w-8 animate-spin text-[#9B1B2E]\" />\r\n        </div>\r\n      ) : (\r\n        <>\r\n          {/* KPIs CA */}\r\n          <section>\r\n            <h2 className=\"text-sm font-bold text-zinc-800 flex items-center gap-2 mb-4\">\r\n              <Banknote className=\"h-4 w-4 text-[#9B1B2E]\" />\r\n              Chiffre d&apos;affaires\r\n            </h2>\r\n            <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4\">\r\n              {[\r\n                { label: 'CA total', value: formatGn(rapport.chiffreAffaires.total), sub: 'Commandes pay├®es / livr├®es' },\r\n                { label: 'Commandes', value: String(rapport.chiffreAffaires.commandes), sub: 'Sur la p├®riode' },\r\n                { label: 'Panier moyen', value: formatGn(rapport.chiffreAffaires.panierMoyen), sub: 'Par commande' },\r\n                {\r\n                  label: '├ëvolution',\r\n                  value: formatPct(rapport.chiffreAffaires.evolutionPct),\r\n                  sub: 'Vs p├®riode pr├®c├®dente',\r\n                  highlight:\r\n                    rapport.chiffreAffaires.evolutionPct != null &&\r\n                    rapport.chiffreAffaires.evolutionPct >= 0,\r\n                },\r\n              ].map((k) => (\r\n                <div\r\n                  key={k.label}\r\n                  className=\"rounded-xl border border-[#F2D4DC] bg-white p-5 shadow-sm\"\r\n                >\r\n                  <p className=\"text-[10px] font-bold uppercase tracking-wider text-zinc-500\">\r\n                    {k.label}\r\n                  </p>\r\n                  <p\r\n                    className={`text-xl md:text-2xl font-bold mt-1 ${\r\n                      k.label === '├ëvolution' && k.highlight ? 'text-emerald-600' : 'text-zinc-900'\r\n                    }`}\r\n                  >\r\n                    {k.value}\r\n                  </p>\r\n                  <p className=\"text-[11px] text-zinc-400 mt-1\">{k.sub}</p>\r\n                </div>\r\n              ))}\r\n            </div>\r\n          </section>\r\n\r\n          <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n            <div className=\"rounded-xl border border-[#F2D4DC] bg-white p-6 shadow-sm\">\r\n              <h3 className=\"font-semibold text-zinc-900 mb-4 flex items-center gap-2\">\r\n                <BarChart3 className=\"h-4 w-4 text-[#9B1B2E]\" />\r\n                CA par jour\r\n              </h3>\r\n              <BarChart\r\n                data={rapport.chiffreAffaires.parJour.map((d) => ({\r\n                  date: d.date,\r\n                  montant: d.montant,\r\n                }))}\r\n                valueKey=\"montant\"\r\n                labelKey=\"date\"\r\n                maxValue={maxCaJour}\r\n              />\r\n            </div>\r\n\r\n            <div className=\"rounded-xl border border-[#F2D4DC] bg-white p-6 shadow-sm\">\r\n              <h3 className=\"font-semibold text-zinc-900 mb-4 flex items-center gap-2\">\r\n                <BarChart3 className=\"h-4 w-4 text-[#9B1B2E]\" />\r\n                CA par mois\r\n              </h3>\r\n              <BarChart\r\n                data={rapport.chiffreAffaires.parMois.map((d) => ({\r\n                  mois: d.mois,\r\n                  montant: d.montant,\r\n                }))}\r\n                valueKey=\"montant\"\r\n                labelKey=\"mois\"\r\n                maxValue={maxCaMois}\r\n              />\r\n            </div>\r\n          </div>\r\n\r\n          {/* Top produits */}\r\n          <section className=\"rounded-xl border border-[#F2D4DC] bg-white p-6 shadow-sm\">\r\n            <h2 className=\"text-sm font-bold text-zinc-800 flex items-center gap-2 mb-4\">\r\n              <Package className=\"h-4 w-4 text-[#9B1B2E]\" />\r\n              Produits les plus vendus\r\n            </h2>\r\n            {rapport.topProduits.length === 0 ? (\r\n              <p className=\"text-sm text-zinc-400 py-6 text-center\">\r\n                Aucune vente enregistr├®e sur cette p├®riode.\r\n              </p>\r\n            ) : (\r\n              <div className=\"overflow-x-auto\">\r\n                <table className=\"w-full min-w-[480px] text-sm\">\r\n                  <thead>\r\n                    <tr className=\"border-b border-zinc-100 text-left text-[11px] uppercase tracking-wider text-zinc-500\">\r\n                      <th className=\"pb-3 pr-4 font-bold\">Produit</th>\r\n                      <th className=\"pb-3 pr-4 font-bold text-right\">Qt├® vendue</th>\r\n                      <th className=\"pb-3 font-bold text-right\">CA g├®n├®r├®</th>\r\n                    </tr>\r\n                  </thead>\r\n                  <tbody>\r\n                    {rapport.topProduits.map((p, i) => (\r\n                      <tr key={p.productId} className=\"border-b border-zinc-50 last:border-0\">\r\n                        <td className=\"py-3 pr-4\">\r\n                          <Link\r\n                            href={`/produits/${p.slug}`}\r\n                            className=\"flex items-center gap-3 hover:text-[#9B1B2E] transition group\"\r\n                          >\r\n                            <div className=\"relative h-11 w-11 shrink-0 rounded-lg overflow-hidden bg-[#FCEEE8] ring-1 ring-[#F2D4DC]\">\r\n                              {p.image && (\r\n                                <Image\r\n                                  src={p.image}\r\n                                  alt=\"\"\r\n                                  fill\r\n                                  className=\"object-cover\"\r\n                                  sizes=\"44px\"\r\n                                />\r\n                              )}\r\n                            </div>\r\n                            <div>\r\n                              <span className=\"text-[10px] text-zinc-400 font-bold\">#{i + 1}</span>\r\n                              <p className=\"font-medium text-zinc-900 group-hover:underline line-clamp-1\">\r\n                                {p.nom}\r\n                              </p>\r\n                            </div>\r\n                          </Link>\r\n                        </td>\r\n                        <td className=\"py-3 pr-4 text-right font-semibold tabular-nums\">\r\n                          {p.quantiteVendue}\r\n                        </td>\r\n                        <td className=\"py-3 text-right font-semibold text-[#9B1B2E] tabular-nums\">\r\n                          {formatGn(p.chiffreAffaires)}\r\n                        </td>\r\n                      </tr>\r\n                    ))}\r\n                  </tbody>\r\n                </table>\r\n              </div>\r\n            )}\r\n          </section>\r\n\r\n          {/* Clients */}\r\n          <section>\r\n            <h2 className=\"text-sm font-bold text-zinc-800 flex items-center gap-2 mb-4\">\r\n              <Users className=\"h-4 w-4 text-[#9B1B2E]\" />\r\n              Analyse des clients\r\n            </h2>\r\n            <div className=\"grid grid-cols-2 lg:grid-cols-5 gap-4 mb-6\">\r\n              {[\r\n                { label: 'Inscrits', value: rapport.clients.inscrits },\r\n                { label: 'Clients actifs', value: rapport.clients.clientsActifs },\r\n                { label: 'Commandes invit├®', value: rapport.clients.commandesInvite },\r\n                { label: 'Fid├®lit├®', value: `${rapport.clients.tauxFidelite} %` },\r\n                { label: 'Panier moyen', value: formatGn(rapport.clients.panierMoyen) },\r\n              ].map((k) => (\r\n                <div\r\n                  key={k.label}\r\n                  className=\"rounded-xl border border-[#F2D4DC] bg-white p-4 shadow-sm text-center\"\r\n                >\r\n                  <p className=\"text-[10px] font-bold uppercase text-zinc-500\">{k.label}</p>\r\n                  <p className=\"text-lg font-bold text-zinc-900 mt-1\">{k.value}</p>\r\n                </div>\r\n              ))}\r\n            </div>\r\n\r\n            <div className=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n              <div className=\"rounded-xl border border-[#F2D4DC] bg-white p-6 shadow-sm\">\r\n                <h3 className=\"font-semibold mb-4\">Top clients (CA)</h3>\r\n                <ul className=\"space-y-3\">\r\n                  {rapport.clients.topClients.map((c, i) => (\r\n                    <li key={c.id ?? i} className=\"flex justify-between gap-2 text-sm\">\r\n                      <div className=\"min-w-0\">\r\n                        <p className=\"font-medium text-zinc-900 truncate\">{c.nom}</p>\r\n                        <p className=\"text-[11px] text-zinc-400 truncate\">{c.email ?? 'ÔÇö'}</p>\r\n                      </div>\r\n                      <div className=\"text-right shrink-0\">\r\n                        <p className=\"font-bold text-[#9B1B2E]\">{formatGn(c.totalDepense)}</p>\r\n                        <p className=\"text-[10px] text-zinc-400\">{c.commandes} cmd.</p>\r\n                      </div>\r\n                    </li>\r\n                  ))}\r\n                  {rapport.clients.topClients.length === 0 && (\r\n                    <p className=\"text-sm text-zinc-400\">Aucun client identifi├®.</p>\r\n                  )}\r\n                </ul>\r\n              </div>\r\n\r\n              <div className=\"rounded-xl border border-[#F2D4DC] bg-white p-6 shadow-sm\">\r\n                <h3 className=\"font-semibold mb-4\">R├®partition par ville</h3>\r\n                <BarChart\r\n                  data={rapport.clients.repartitionVilles.map((v) => ({\r\n                    ville: v.ville,\r\n                    commandes: v.commandes,\r\n                  }))}\r\n                  valueKey=\"commandes\"\r\n                  labelKey=\"ville\"\r\n                  maxValue={Math.max(\r\n                    ...(rapport.clients.repartitionVilles.map((v) => v.commandes) ?? [1]),\r\n                    1,\r\n                  )}\r\n                />\r\n              </div>\r\n            </div>\r\n          </section>\r\n\r\n          {/* Pr├®visions */}\r\n          <section className=\"rounded-xl border border-[#F2D4DC] bg-white p-6 shadow-sm\">\r\n            <h2 className=\"text-sm font-bold text-zinc-800 flex items-center gap-2 mb-4\">\r\n              <TrendingUp className=\"h-4 w-4 text-[#9B1B2E]\" />\r\n              Pr├®visions des ventes\r\n            </h2>\r\n            <p className=\"text-xs text-zinc-500 mb-4\">\r\n              Estimation bas├®e sur la moyenne journali├¿re des 30 derniers jours (commandes confirm├®es).\r\n            </p>\r\n            <div className=\"grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6\">\r\n              {[\r\n                { label: 'Moy. / jour', value: formatGn(rapport.previsions.moyenneJournaliere) },\r\n                { label: 'Tendance 7j', value: formatPct(rapport.previsions.tendancePct) },\r\n                { label: 'Pr├®vision 7j', value: formatGn(rapport.previsions.prevision7j) },\r\n                { label: 'Pr├®vision 30j', value: formatGn(rapport.previsions.prevision30j) },\r\n              ].map((k) => (\r\n                <div key={k.label} className=\"rounded-lg bg-[#FFF8F6] border border-[#F2D4DC] p-4\">\r\n                  <p className=\"text-[10px] font-bold uppercase text-zinc-500\">{k.label}</p>\r\n                  <p className=\"text-lg font-bold text-zinc-900 mt-1\">{k.value}</p>\r\n                </div>\r\n              ))}\r\n            </div>\r\n            <h3 className=\"font-semibold text-sm mb-3 flex items-center gap-2\">\r\n              <LineChart className=\"h-4 w-4\" />\r\n              R├®el vs moyenne (7 derniers jours)\r\n            </h3>\r\n            <div className=\"space-y-2\">\r\n              {rapport.previsions.historique7j.map((d) => (\r\n                <div key={d.date} className=\"flex items-center gap-2 text-xs\">\r\n                  <span className=\"w-20 text-zinc-500\">{d.date.slice(5)}</span>\r\n                  <div className=\"flex-1 flex gap-1 h-3\">\r\n                    <div\r\n                      className=\"h-full bg-[#9B1B2E] rounded-sm\"\r\n                      style={{ width: `${maxPrev > 0 ? (d.reel / maxPrev) * 50 : 0}%` }}\r\n                      title={`R├®el: ${formatGn(d.reel)}`}\r\n                    />\r\n                    <div\r\n                      className=\"h-full bg-[#9B1B2E]/30 rounded-sm border border-dashed border-[#9B1B2E]/50\"\r\n                      style={{ width: `${maxPrev > 0 ? (d.prevision / maxPrev) * 50 : 0}%` }}\r\n                      title={`Moyenne: ${formatGn(d.prevision)}`}\r\n                    />\r\n                  </div>\r\n                  <span className=\"w-28 text-right tabular-nums\">\r\n                    <span className=\"font-semibold\">{formatGn(d.reel)}</span>\r\n                    <span className=\"text-zinc-400\"> / {formatGn(d.prevision)}</span>\r\n                  </span>\r\n                </div>\r\n              ))}\r\n            </div>\r\n            <p className=\"text-[10px] text-zinc-400 mt-3\">\r\n              Ôûá R├®el &nbsp; Ôûæ Moyenne 30j\r\n            </p>\r\n          </section>\r\n\r\n          {/* Power BI */}\r\n          <section className=\"rounded-xl border border-[#F2D4DC] bg-white p-6 shadow-sm\">\r\n            <h2 className=\"text-sm font-bold text-zinc-800 flex items-center gap-2 mb-2\">\r\n              <LayoutDashboard className=\"h-4 w-4 text-[#9B1B2E]\" />\r\n              Tableaux de bord Power BI\r\n            </h2>\r\n            {rapport.powerBi.configure && rapport.powerBi.embedUrl ? (\r\n              <div className=\"mt-4 rounded-xl overflow-hidden border border-zinc-200 aspect-video bg-zinc-100\">\r\n                <iframe\r\n                  title=\"Power BI Love Piment&\"\r\n                  src={rapport.powerBi.embedUrl}\r\n                  className=\"w-full h-full min-h-[420px]\"\r\n                  allowFullScreen\r\n                />\r\n              </div>\r\n            ) : (\r\n              <div className=\"mt-4 rounded-xl border-2 border-dashed border-[#F2D4DC] bg-[#FFF8F6] p-8 text-center\">\r\n                <LayoutDashboard className=\"h-10 w-10 mx-auto text-zinc-300 mb-3\" />\r\n                <p className=\"text-sm font-medium text-zinc-700\">Power BI non configur├®</p>\r\n                <p className=\"text-xs text-zinc-500 mt-2 max-w-md mx-auto leading-relaxed\">\r\n                  Ajoutez{' '}\r\n                  <code className=\"bg-white px-1.5 py-0.5 rounded text-[#9B1B2E]\">\r\n                    NEXT_PUBLIC_POWER_BI_EMBED_URL\r\n                  </code>{' '}\r\n                  dans <code className=\"bg-white px-1.5 py-0.5 rounded\">.env.local</code> pour\r\n                  int├®grer votre rapport Power BI (URL d&apos;embed publique ou s├®curis├®e).\r\n                </p>\r\n                {rapport.powerBi.reportUrl && (\r\n                  <a\r\n                    href={rapport.powerBi.reportUrl}\r\n                    target=\"_blank\"\r\n                    rel=\"noopener noreferrer\"\r\n                    className=\"inline-flex items-center gap-2 mt-4 text-sm font-semibold text-[#9B1B2E] hover:underline\"\r\n                  >\r\n                    Ouvrir le rapport Power BI\r\n                    <ExternalLink className=\"h-4 w-4\" />\r\n                  </a>\r\n                )}\r\n              </div>\r\n            )}\r\n            {rapport.powerBi.reportUrl && rapport.powerBi.embedUrl && (\r\n              <a\r\n                href={rapport.powerBi.reportUrl}\r\n                target=\"_blank\"\r\n                rel=\"noopener noreferrer\"\r\n                className=\"inline-flex items-center gap-2 mt-4 text-sm font-medium text-[#9B1B2E] hover:underline\"\r\n              >\r\n                Ouvrir dans Power BI\r\n                <ExternalLink className=\"h-4 w-4\" />\r\n              </a>\r\n            )}\r\n          </section>\r\n        </>\r\n      )}\r\n    </div>\r\n  );\r\n}\r\n","usedDep